//AXI GPIO driver
#include "xgpio.h"

//send data over UART
#include "xil_printf.h"

//information about AXI peripherals
#include "xparameters.h"

#include <stdio.h>
#include <stdlib.h>
#include <string.h>

int main()
{
	char buffer[20];
	char *delimiter;
	int a, b;
	int i;
	char c;

	while(1) {
		xil_printf("Enter Expression: ");
		i = 0;
		while (1) {
			c = inbyte();
			outbyte(c);

			if (c == '\r' || c == '\n') {
				buffer[i] = '\0';
				break;
			}
			if (i < sizeof(buffer) - 1) {
				buffer[i] = c;
				i++;
			}
		}
		xil_printf("\n");
		if (fgets(buffer, sizeof(buffer), stdin) == NULL) {
			continue;
		}
		delimiter = strchr(buffer, '*');
		if (delimiter == NULL) {
			xil_printf("Invalid Expression\n");
		}
		*delimiter = '\0';
		a = atoi(buffer);
		b = atoi(delimiter + 1);
		xil_printf("Result: %d\n", a*b);
	}


	return 0;
}
