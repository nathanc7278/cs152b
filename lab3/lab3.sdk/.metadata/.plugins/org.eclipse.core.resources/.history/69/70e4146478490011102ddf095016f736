int main()
{
    char buffer[20];
    int i = 0;
    char c;

    xil_printf("Enter numbers: \r\n");

    // Read until newline, buffer full, or carriage return
    while (i < (int)(sizeof(buffer) - 1)) {
        c = getchar();
        if (c == '\r' || c == '\n') break;
        buffer[i++] = c;
        xil_printf("%c", c); // echo character back to PuTTY
    }
    buffer[i] = '\0';

    xil_printf("\r\nYou entered: %s\r\n", buffer);
    return 0;
}
